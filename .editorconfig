# EditorConfig — enforces the C# style in agent-standards/20-csharp-style.md
# This is the mechanical counterpart to the written standard. Keep the two in sync.
root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml}]
trim_trailing_whitespace = false

[*.{json,csproj,props,targets,xml}]
indent_size = 2

[*.cs]
indent_size = 4

# --- File-scoped namespaces ---
csharp_style_namespace_declarations = file_scoped:warning

# --- Allman braces: every brace on its own line ---
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true

# --- Always use braces ---
csharp_prefer_braces = true:warning

# --- 'using' directives outside namespace, System first, sorted ---
csharp_using_directive_placement = outside_namespace:warning
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# --- var usage: only when the type is apparent ---
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# --- Modern language features ---
csharp_style_prefer_primary_constructors = true:suggestion
csharp_style_expression_bodied_methods = when_on_single_line:suggestion
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion
csharp_prefer_simple_using_statement = true:suggestion
dotnet_style_prefer_collection_expression = true:suggestion

# --- Nullable / quality ---
dotnet_style_require_accessibility_modifiers = always:warning
dotnet_style_readonly_field = true:suggestion

# =====================================================================
# Naming rules
# =====================================================================

# Interfaces: IPascalCase
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.severity = warning
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.symbols = interface_symbols
dotnet_naming_rule.interfaces_should_be_prefixed_with_i.style = i_prefix_pascal_case
dotnet_naming_symbols.interface_symbols.applicable_kinds = interface
dotnet_naming_style.i_prefix_pascal_case.capitalization = pascal_case
dotnet_naming_style.i_prefix_pascal_case.required_prefix = I

# Types & members: PascalCase
dotnet_naming_rule.types_and_members_pascal_case.severity = warning
dotnet_naming_rule.types_and_members_pascal_case.symbols = type_and_member_symbols
dotnet_naming_rule.types_and_members_pascal_case.style = pascal_case_style
dotnet_naming_symbols.type_and_member_symbols.applicable_kinds = class, struct, enum, property, method, event, delegate
dotnet_naming_style.pascal_case_style.capitalization = pascal_case

# Private fields: _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_field_symbols
dotnet_naming_rule.private_fields_underscore.style = underscore_camel_case
dotnet_naming_symbols.private_field_symbols.applicable_kinds = field
dotnet_naming_symbols.private_field_symbols.applicable_accessibilities = private
dotnet_naming_style.underscore_camel_case.capitalization = camel_case
dotnet_naming_style.underscore_camel_case.required_prefix = _

# Constants: PascalCase
dotnet_naming_rule.constants_pascal_case.severity = warning
dotnet_naming_rule.constants_pascal_case.symbols = constant_symbols
dotnet_naming_rule.constants_pascal_case.style = pascal_case_style
dotnet_naming_symbols.constant_symbols.applicable_kinds = field, local
dotnet_naming_symbols.constant_symbols.required_modifiers = const

# Parameters & locals: camelCase
dotnet_naming_rule.parameters_camel_case.severity = suggestion
dotnet_naming_rule.parameters_camel_case.symbols = parameter_symbols
dotnet_naming_rule.parameters_camel_case.style = camel_case_style
dotnet_naming_symbols.parameter_symbols.applicable_kinds = parameter, local
dotnet_naming_style.camel_case_style.capitalization = camel_case

# =====================================================================
# StyleCop diagnostic overrides
# =====================================================================

# SA1309: Allow _camelCase prefix on private fields (project convention)
dotnet_diagnostic.SA1309.severity = none

# SA1101: Do not require this. prefix on instance member access
dotnet_diagnostic.SA1101.severity = none

# SA1633: Do not require file header copyright comments
dotnet_diagnostic.SA1633.severity = none

# CA1034: Allow public nested types (used for discriminated union patterns)
dotnet_diagnostic.CA1034.severity = none

# CA1707: Allow underscores in test method names (Given_When_Then convention)
dotnet_diagnostic.CA1707.severity = none

# SA1316: Suppress tuple element casing rule — single-letter colour component names (r,g,b) are standard
dotnet_diagnostic.SA1316.severity = none
